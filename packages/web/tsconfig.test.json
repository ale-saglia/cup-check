{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "noImplicitAny": false,
    "noEmit": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": false,
    "types": ["vitest/globals", "node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.svelte",
    "src/**/*.d.ts",
    "tests/**/*.d.ts",
    "tests/**/*.test.ts"
  ]
}
