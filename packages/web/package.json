    "pdfjs-dist": "^6.0.227",
    "read-excel-file": "^9.0.10",
    "sql.js": "^1.14.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "^2.0.1",
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/svelte": "^5.3.1",
    "@types/papaparse": "^5.5.2",
    "@types/sql.js": "^1.4.11",
    "@vitest/coverage-v8": "^4.1.8",
    "axe-core": "^4.11.4",
    "canvas": "^3.2.3",
    "eslint": "^10.4.1",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "js-yaml": "^4.2.0",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "lighthouse": "^13.3.0",
    "playwright": "^1.60.0",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^4.1.0",
    "svelte": "^5.56.0",
    "svelte-check": "^4.4.8",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.15",
    "vitest": "^4.1.8"
  }
