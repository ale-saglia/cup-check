{
  "name": "@cup-check/web",
  "private": true,
  "license": "EUPL-1.2",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest",
    "test:coverage": "vitest --run --coverage --reporter=default --reporter=junit --outputFile.junit=junit.xml",
    "test:acceptance": "node tests/acceptance.mjs",
    "test:lighthouse": "node tests/lighthouse.mjs",
    "check": "svelte-check --tsconfig tsconfig.json",
    "check:tests": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint .",
    "format": "prettier --write . ../../tests/fixtures"
  },
  "dependencies": {
    "@tesseract.js-data/eng": "^1.0.0",
    "@tesseract.js-data/ita": "^1.0.0",
