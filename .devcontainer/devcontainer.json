{
  "name": "cup-check",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "alexcvzz.vscode-sqlite",
        "ms-python.python",
        "vitest.explorer"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "eslint.workingDirectories": ["packages/web"],
        "npm.autoDetect": "off",
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": false,
        "taskexplorer.useNpmProvider": true
      }
    }
  },
  "containerEnv": {},
  "forwardPorts": [5173, 5900, 9000],
  "portsAttributes": {
    "5173": {
      "label": "Vite dev server",
      "onAutoForward": "notify"
    },
    "4174": {
      "label": "Vite preview (legacy target)",
      "onAutoForward": "ignore"
    },
    "5900": {
      "label": "VNC raw (Chromium legacy)",
      "onAutoForward": "ignore"
    },
    "9000": {
      "label": "noVNC (Chromium legacy)",
      "onAutoForward": "ignore"
    }
  },
  "postCreateCommand": "make setup",
  "remoteUser": "vscode"
}
